{
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(task set-status *)",
      "Bash(agent ps *)",
      "Bash(go vet *)",
      "Bash(wezterm cli list *)",
      "Bash(task ls *)",
      "Bash(gh search *)",
      "WebSearch",
      "WebFetch(domain:docs.claude.com)",
      "Bash(go test *)",
      "Bash(go install *)",
      "mcp__plugin_work_ground__ground",
      "mcp__plugin_work_grill__grill_search",
      "mcp__plugin_work_grill__grill_save_session",
      "mcp__plugin_work_task__create_task",
      "mcp__plugin_work_task__list_tasks",
      "mcp__plugin_work_task__set_task_status",
      "mcp__plugin_work_task__task_tree",
      "mcp__plugin_work_session__set_phase",
      "WebFetch(domain:cmux.com)",
      "Read(/Users/cenk/.work/**)",
      "Read(/Users/cenk/.work/schemas/**)",
      "Read(/Users/cenk/projects/teleport/**)",
      "Read(/tmp/**)",
      "mcp__claude_ai_Gmail__search_threads"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "disableAgentView": true,
  "statusLine": {
    "type": "command",
    "command": "agent statusline"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "work@work-dev": true,
    "teleport@harness-teleport": true
  },
  "extraKnownMarketplaces": {
    "harness-teleport": {
      "source": {
        "source": "directory",
        "path": "/Users/cenk/projects/harness-teleport"
      }
    },
    "work-dev": {
      "source": {
        "source": "directory",
        "path": "/Users/cenk/projects/harness"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org",
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.work",
        "~/projects",
        "~/go",
        "~/Library/Caches/go-build"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/Library/Keychains",
        "~/.netrc",
        "~/.pgpass",
        "~/.zshrc",
        "~/.bashrc"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/Library/Keychains",
        "~/.netrc",
        "~/.pgpass"
      ]
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "theme": "dark",
  "editorMode": "normal",
  "verbose": false,
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true
}
